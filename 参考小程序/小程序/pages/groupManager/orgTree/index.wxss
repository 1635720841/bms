.t_container {
  padding: 10px;
}

.selection-bar{
  width: 100%;
  padding: 10rpx 30rpx 30rpx 30rpx;
  display: flex;
  flex-direction: column;
  background-color: #f1f1f1;
  border-radius: 10rpx;
  margin-bottom: 30rpx;
}

.select-btns{
  margin-top: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.confirm-btn{
  width: 100rpx;
  height: 60rpx;
  border-radius: 10rpx;
   background-color: var(--green);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  
}

.confirm-btn:active{
  opacity: 0.7;
}

.cancel-btn{
  width: 100rpx;
  height: 60rpx;
  border-radius: 10rpx;
  margin-left: 30rpx;
  background-color: var(--grey);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn{
  opacity: 0.7;
}


