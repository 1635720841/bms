/* pages/deviceManager/configuration/configuration.wxss */

@import "../deviceEntry/deviceEntry.wxss";


.param-search-picker {
  width: 100%;
  height: 80rpx;
  padding: 0 30rpx;
  border: 2rpx solid #e6e4e4;
  border-radius: 8rpx;
  background: #f7f7f7;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  color: #666;
  display: flex;
  justify-content: space-between;
}

.param-row {
  width: 100%;
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
  flex-wrap: wrap;
}


.table {
  width: 100%;
  margin: 0 auto;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #ccc;
  margin-top: 10rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.table-row {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #ccc;
  /* padding: 10rpx 0; */
  min-width: 100%;
}

/* .table-cell {
  flex-shrink: 0;
  text-align: center;
  padding: 12rpx 10rpx;
  font-size: 24rpx;
  color: #333;
} */

.table-header {
  background: #ededed;
  font-weight: bold;
}

.table-cell {
  flex: 1;
  /* text-align: center; */
  padding: 15rpx 0 15rpx 30rpx;
  font-size: 24rpx;
  color: #333;
}

.table-row:last-child {
  border-bottom: none;
}