.section {
  position: relative;
  border-radius: 20rpx;
  padding: 64rpx 16rpx 16rpx 16rpx;
  width: 96%;
  border: 2px solid white;
  background: #ededed;
  margin-top: 50rpx ;
}

.section-title-hex {
  position: absolute;
  left: 50%;
  top: -28rpx;
  transform: translateX(-50%);
  width: 260rpx;
  height: 56rpx;
  background: #fff;
  color: #333;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  clip-path: polygon(10% 0, 90% 0, 100% 50%, 90% 100%, 10% 100%, 0 50%);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  z-index: 2;
}
 

