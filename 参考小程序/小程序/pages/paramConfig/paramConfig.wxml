        </view>

        <view class="metallic-button chrome {{activeSize}} {{cellOVUpdatePressed ? 'pressed' : ''}}" data-type="cellOV" data-op="Update" bindtouchstart="buttonTouchStart" bindtouchend="buttonTouchEnd" bindtouchcancel="buttonTouchCancel" hover-class="metallic-button-active" catch:tap="onUpdateParams">
          <view class="button-content">
            <text class="button-text">更新</text>
          </view>
          <view class="shine"></view>
          <view class="press-effect chrome {{cellOVUpdatePressed ? 'active' : ''}}"></view>
          <view class="inner-shadow {{cellOVUpdatePressed ? 'active' : ''}}"></view>
        </view>
      </view>
    </view>

    <!-- 电芯欠压保护 -->
    <view class="section section-has-title">
      <view class="section-title-hex" id="section-4">电芯欠压保护</view>
      <view class="param-row">
        <view class="param-col2">
