<view class="container">
  <!-- 下拉刷新加载指示器 -->
  <view class="refresher" wx:if="{{refreshing}}">
    <view class="refresher-content">
      <loading type="circle" color="#666"></loading>
      <text>加载中...</text>
    </view>
  </view>
  <!-- 顶部输入 -->
  <view class="top-bar">
    <view class="input-bg">
      <input class="device-input" placeholder="请输入设备编码" value="{{deviceCode}}" bindinput="onDeviceCodeInput" bindconfirm="onDeviceCodeConfirm" />
      <text wx:if="{{!!deviceCode}}" class="iconfont icon-guanbi" style="font-size: 48rpx;color: gray;padding: 10rpx ;" catch:tap="clearCode"></text>
      <text class="iconfont icon-iconfontscan" style="font-size: 48rpx;color: var(--mainThemeText);padding: 10rpx 20rpx;" catch:tap="onScanCode"></text>
    </view>
  </view>

  <!-- 参数查找下拉选择板块 -->
  <view wx:if="{{!!deviceCode && params}}" class="param-search-row">
    <text class="param-search-label">参数查找</text>
    <picker mode="selector" style="width: 80%;" range="{{sectionList}}" bindchange="onSectionChange">
      <view class="param-search-picker" style="width: 80%;">{{sectionList[selectedSection]}}
        <text class="iconfont icon-xiala" style="font-size: 36rpx;padding: 10rpx 0;color: gray;"></text>
      </view>

    </picker>
  </view>

  <scroll-view wx:if="{{!!deviceCode && params}}" scroll-y="true" class="param-scroll" scroll-into-view="section-{{selectedSection}}" enable-flex="true" adjust-position="false">


    <!-- BT码设置 -->
    <view class="section section-has-title">
      <view class="section-title-hex" id="section-0">BT码设置</view>
      <view class="param-row">
        <text>BT码</text>
        <text class="param-input btcode-input" style="width: 70%;margin-left: 10rpx;" catch:tap="onSetBtCode">{{ generatedBtCode || '点击设置BT码'}}</text>
        <text wx:if="{{!!generatedBtCode}}" style="font-size: 24rpx ;margin-left: 10rpx;color: var(--mainThemeText);" catch:tap="onCopyBtcode">复制</text>
      </view>
      <view class="param-row" style="margin-top: -10rpx; margin-bottom: 20rpx;">
        <text style="font-size: 24rpx; color: #888;">格式: BT+材料+电压+容量+循环寿命+厂家+年月日+流水号</text>
      </view>
      <view class="param-btn-group">
        <view class="metallic-button chrome {{activeSize}} {{BTcodeWritePressed ? 'pressed' : ''}}" data-type="BTcode" data-op="Write" bindtouchstart="buttonTouchStart" bindtouchend="buttonTouchEnd" bindtouchcancel="buttonTouchCancel" hover-class="metallic-button-active" catch:tap="onBTcodeWrite">
          <view class="button-content">
            <text class="button-text">写入</text>
          </view>
          <view class="shine"></view>
          <view class="press-effect chrome {{BTcodeWritePressed ? 'active' : ''}}"></view>
          <view class="inner-shadow {{BTcodeWritePressed ? 'active' : ''}}"></view>
        </view>
        <view class="metallic-button chrome {{activeSize}} {{BTcodeUpdatePressed ? 'pressed' : ''}}" data-type="BTcode" data-op="Update" bindtouchstart="buttonTouchStart" bindtouchend="buttonTouchEnd" bindtouchcancel="buttonTouchCancel" hover-class="metallic-button-active" catch:tap="onUpdateBtcoeOrServer">
          <view class="button-content">
            <text class="button-text">更新</text>
          </view>
          <view class="shine"></view>
          <view class="press-effect chrome {{BTcodeUpdatePressed ? 'active' : ''}}"></view>
          <view class="inner-shadow {{BTcodeUpdatePressed ? 'active' : ''}}"></view>
        </view>
      </view>
    </view>
    <!-- 三方后台配置 -->
    <view class="section section-has-title">
      <view class="section-title-hex" id="section-1">三方后台配置</view>
      <view class="param-row">
        <text>服务器地址</text>
        <view class="param-col" style="margin-left: 10rpx;width: 60%;">
           <picker style="width: 100%;" mode="selector" range="{{thirdSrvList}}" range-key="title" bindchange="onThirdSrvChage">
            <view class="param-picker" style="width: 80%;">
              <text style="width: 80%;">{{thirdSrv.title}}</text>
              <text class="iconfont icon-xiala" style="font-size: 36rpx;padding: 10rpx 0;color: gray;"></text>
            </view>
          </picker>
        </view>

      </view>
      <view class="param-row" style="margin-top: -10rpx; margin-bottom: 20rpx;">
        <text style="font-size: 24rpx; color: #888;">格式: 域名:端口 或者 IP:端口</text>
      </view>
      <view class="param-btn-group">
        <view class="metallic-button chrome {{activeSize}} {{TServerWritePressed ? 'pressed' : ''}}" data-type="TServer" data-op="Write" bindtouchstart="buttonTouchStart" bindtouchend="buttonTouchEnd" bindtouchcancel="buttonTouchCancel" hover-class="metallic-button-active" catch:tap="onTServerSave">
          <view class="button-content">
            <text class="button-text">写入</text>
          </view>
          <view class="shine"></view>
          <view class="press-effect chrome {{TServerSavePressed ? 'active' : ''}}"></view>
          <view class="inner-shadow {{TServerSavePressed ? 'active' : ''}}"></view>
        </view>
        <view class="metallic-button chrome {{activeSize}} {{TServerUpdatePressed ? 'pressed' : ''}}" data-type="TServer" data-op="Update" bindtouchstart="buttonTouchStart" bindtouchend="buttonTouchEnd" bindtouchcancel="buttonTouchCancel" hover-class="metallic-button-active" catch:tap="onUpdateBtcoeOrServer">
          <view class="button-content">
            <text class="button-text">更新</text>
          </view>
          <view class="shine"></view>
          <view class="press-effect chrome {{TServerUpdatePressed ? 'active' : ''}}"></view>
          <view class="inner-shadow {{TServerUpdatePressed ? 'active' : ''}}"></view>
        </view>
      </view>
    </view>

    <!-- 基础参数 -->
    <view class="section section-has-title">
      <view class="section-title-hex" id="section-2">基础参数</view>
      <view class="param-row">
        <view class="param-col2">
          <view style="display: flex;flex-direction: row;">
            <text>电芯材料</text>
            <text style="width: 50rpx;"></text>
          </view>
          <picker mode="selector" range="{{materialArray}}" range-key="title" bindchange="onMaterialChange">
            <view class="param-picker">
              <text>{{selectedMaterial.title}}</text>
              <text class="iconfont icon-xiala" style="font-size: 36rpx;padding: 10rpx 0;color: gray;"></text>
            </view>
          </picker>
        </view>
        <!-- 修改电芯串数为下拉选择 -->
        <view class="param-col">
          <text>电芯串数</text>
          <picker mode="selector" range="{{seriesOptions}}" bindchange="onSeriesChange">
            <view class="param-picker">
              <text>{{params.cell_cnt}}</text>
              <text class="iconfont icon-xiala" style="font-size: 36rpx;padding: 10rpx 0;color: gray;"></text>
            </view>

          </picker>
        </view>

      </view>

      <!-- 修改电芯容量为输入+下拉选择 -->
      <view class="param-col2">
        <view style="display: flex;flex-direction: row;">
          <text>电芯容量</text>
          <text>(Ah)</text>
        </view>

        <view class="param-input-picker">
          <input type="digit" value="{{params.designed_capD}}" bindinput="onCapacityInput" />
          <picker mode="selector" range="{{capacityOptions}}" bindchange="onCapacitySelect">
            <text class="iconfont icon-xiala" style="font-size: 36rpx;padding: 10rpx 0;color: gray;"></text>
          </picker>
        </view>

      </view>
      <view class="param-btn-group">
        <view class="metallic-button chrome {{activeSize}} {{basicParamsWritePressed ? 'pressed' : ''}}" data-type="basicParams" data-op="Write" bindtouchstart="buttonTouchStart" bindtouchend="buttonTouchEnd" bindtouchcancel="buttonTouchCancel" hover-class="metallic-button-active" bindtap="onBasicParamsWrite">
          <view class="button-content">
            <text class="button-text">写入</text>
          </view>
          <view class="shine"></view>
          <view class="press-effect chrome {{basicParamsWritePressed ? 'active' : ''}}"></view>
          <view class="inner-shadow {{basicParamsWritePressed ? 'active' : ''}}"></view>
        </view>
        <view class="metallic-button chrome {{activeSize}} {{basicParamsUpdatePressed ? 'pressed' : ''}}" data-type="basicParams" data-op="Update" bindtouchstart="buttonTouchStart" bindtouchend="buttonTouchEnd" bindtouchcancel="buttonTouchCancel" hover-class="metallic-button-active" catch:tap="onUpdateParams">
          <view class="button-content">
            <text class="button-text">更新</text>
          </view>
          <view class="shine"></view>
          <view class="press-effect chrome {{basicParamsUpdatePressed ? 'active' : ''}}"></view>
          <view class="inner-shadow {{basicParamsUpdatePressed ? 'active' : ''}}"></view>
        </view>
      </view>
    </view>

    <!-- 电芯过压保护 -->
    <view class="section section-has-title">
      <view class="section-title-hex" id="section-3">电芯过压保护</view>
      <view class="param-row">
        <view class="param-col2">
          <view style="display: flex;flex-direction: row;">
            <text>触发门限</text>
