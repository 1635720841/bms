<!-- BT码设置 -->
<page-container show="{{showBtCodeDialog}}" duration="300" position="right" close-on-slide-down="{{false}}" bindbeforeenter="onBeforeEnter" bindenter="onEnter" bindafterenter="onAfterEnter" bindbeforeleave="onBeforeLeave" bindleave="onLeave" bindafterleave="onAfterLeave" bindclickoverlay="onClickOverlay">
 
<!-- <view class="dailog-btcode-container" > -->
  <view class="btcode-dialog">
    <view class="dialog-header">
      <text>{{btDialogTitle}}</text>
      <text class="iconfont icon-guanbi" catch:tap="onCloseBtCodeDialog"></text>
    </view>

    <view class="btcode-form">
      <view class="form-item">
        <text class="label">生产方式</text>
        <radio-group class="modal-radio-group" bindchange="productWayChange">
          <label class="radio-item">
            <radio value="1" checked="{{productWay === 1}}" style="transform: scale(0.8);" /> 自动生成
          </label>
          <label class="radio-item">
            <radio value="2" checked="{{productWay === 2}}" style="transform: scale(0.8);margin-left: 50rpx;" /> 自定义
          </label>
        </radio-group>
      </view>

      <!-- 产品名称 (固定BT) -->
      <view class="form-item">
        <text class="label">产品名称</text>
        <text class="value">BT</text>
      </view>

      <!-- 材料体系 -->
      <view class="form-item">
        <text class="label">材料体系</text>
        <!-- <text class="value">{{btMaterialOptions[btMaterialIndex]}}</text> -->
        <picker mode="selector" range="{{materialArray}}" range-key="title" bindchange="onMaterialChange222">
          <view class="param-picker" style="width: 200rpx;">
            <text style="padding-left: 10rpx;font-size: 28rpx;color: #333;">{{btMaterialOptions[btMaterialIndex]}}</text>
            <text class="iconfont icon-xiala" style="font-size: 36rpx;padding: 10rpx 0;color: gray;"></text>
          </view>
        </picker>
      </view>

      <!-- 电压等级 -->
      <view class="form-item">
        <text class="label">电压等级</text>
        <input type="number" value="{{btVoltageValue}}" placeholder="048(48V)" maxlength="3" bindinput="onBtVoltageInput" class="voltage-input manufacturer-input" />
      </view>

      <!-- 容量等级 -->
      <view class="form-item">
        <text class="label">容量等级</text>
        <input type="number" value="{{btCapacityValue}}" bindinput="onBtCapacityInput" placeholder="020(20Ah)" maxlength="3" class="capacity-input manufacturer-input" />
      </view>

      <!-- 循环寿命 -->
      <view class="form-item">
        <text class="label">循环寿命</text>
        <input type="number" value="{{btCycleLifeValue}}" bindinput="onBtCycleLifeInput" placeholder="12(1200次)" maxlength="2" class="life-input manufacturer-input" />
      </view>

      <!-- 厂家代码 -->
      <view class="form-item">
        <text class="label">厂家代码</text>
        <input type="text" value="{{btManufacturerValue}}" bindinput="onbtManufacturerValueInput" placeholder="输入4位厂家代码" maxlength="4" class="manufacturer-input" />
      </view>

      <!-- 生产年份 -->
      <!-- <view class="form-item">
        <text class="label">生产年份</text>
        <input type="number" value="{{btProductionYear}}" bindinput="onBtProductionYearInput" placeholder="25(2025)" maxlength="2" class="year-input" />
      </view> -->

      <!-- 生产月份 -->
      <!-- <view class="form-item">
        <text class="label">生产月份</text>
        <input type="number" value="{{btProductionMonth}}" bindinput="onBtProductionMonthInput" placeholder="05(5月)" maxlength="2" class="month-input" />
      </view> -->

      <!-- 生产日期 -->
      <!-- <view class="form-item">
        <text class="label">生产日期</text>
        <input type="number" value="{{btProductionDay}}" bindinput="onBtProductionDayInput" placeholder="07(7号)" maxlength="2" class="day-input" />
      </view> -->

       <!-- 生产年份 -->
       <view wx:if="{{productWay === 1}}" class="form-item">
        <text class="label">生产年份</text>
         <picker mode="date" fields="year" start="{{starTimeY}}" end="{{endTimeY}}" header-text="选择年份" bindchange="onBtYearChange222" >
          <view class="param-picker" style="width: 200rpx;">
            <text style="padding-left:10rpx;font-size: 28rpx;color: #333;">{{btProductionYear}}</text>
            <text class="iconfont icon-xiala" style="font-size: 36rpx;padding: 10rpx 0;color: gray;"></text>
          </view>
        </picker>
      </view>

      <!-- 生产日期 -->
      <view wx:if="{{productWay === 2}}" class="form-item">
        <text class="label">生产日期</text>
         <picker mode="date" fields="day" start="{{starTimeD}}" end="{{endTimeD}}" bindchange="onBtDayChange222" >
          <view class="param-picker" style="width: 200rpx;">
            <text style="    padding-left: 10rpx;font-size: 28rpx;color: #333;">{{btProductionYear}}{{btProductionMonth}}{{btProductionDay}}</text>
            <text class="iconfont icon-xiala" style="font-size: 36rpx;padding: 10rpx 0;color: gray;"></text>
          </view>
        </picker>
      </view>

      <!-- 流水号 -->
      <view wx:if="{{productWay === 2}}" class="form-item">
        <text class="label">流水号</text>
        <input type="number" value="{{btSerialNumber}}" bindinput="onBtSerialNumberInput" placeholder="001" maxlength="3" class="serial-input" />
      </view>

      <!-- 生成的BT码预览 -->
      <view wx:if="{{isShowPreview}}" class="btcode-preview">
        <text class="preview-label">BT码预览:</text>
        <text class="preview-value">{{prview_bt_code}}</text>
      </view>
    </view>

    <view class="dialog-buttons">
      <button class="dialog-btn cancel" catch:tap="onCloseBtCodeDialog">取消</button>
      <button class="dialog-btn preview" catch:tap="onPreviewBtCode">预览</button>
      <button class="dialog-btn confirm" catch:tap="onValidateAndConfirmBtCode">确认</button>
    </view>
  </view>
