      </view>
      <view class="param-btn-group">
        <view class="metallic-button chrome {{activeSize}} {{cellUVWritePressed ? 'pressed' : ''}}" data-type="cellUV" data-op="Write" bindtouchstart="buttonTouchStart" bindtouchend="buttonTouchEnd" bindtouchcancel="buttonTouchCancel" hover-class="metallic-button-active" catchtap="onCellUVWrite">
