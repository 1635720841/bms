        </view>
        <view class="metallic-button chrome {{activeSize}} {{cellUVUpdatePressed ? 'pressed' : ''}}" data-type="cellUV" data-op="Update" bindtouchstart="buttonTouchStart" bindtouchend="buttonTouchEnd" bindtouchcancel="buttonTouchCancel" hover-class="metallic-button-active" catch:tap="onUpdateParams">
