            </picker>
          </view>
        </view>
      </view>
      <view class="param-btn-group">
        <view class="metallic-button chrome {{activeSize}} {{cellOVWritePressed ? 'pressed' : ''}}" data-type="cellOV" data-op="Write" bindtouchstart="buttonTouchStart" bindtouchend="buttonTouchEnd" bindtouchcancel="buttonTouchCancel" hover-class="metallic-button-active" catch:tap="onCellOVWrite">
