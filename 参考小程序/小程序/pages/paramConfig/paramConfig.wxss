/* 下拉刷新样式 */
.refresher {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.refresher-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.refresher-content image {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
  animation: rotate 1s linear infinite;
}

.refresher-content text {
  font-size: 28rpx;
  color: #666;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 参数配置页面样式 */

.container {
  padding: 20rpx;
  background: #f8f8f8;
}

.top-bar {
  width: 100%;
}

.input-bg {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 10rpx;
  padding: 0 10rpx;
  width: 96%;
  box-sizing: border-box;
  height: 80rpx;
}

.device-input {
  width: 80%;
  height: 100%;
  border: none;
  background: transparent;
  padding-left: 30rpx;
  font-size: 28rpx;
}

.param-scroll {
  height: calc(100vh - 150px);
  width: 100%;
  padding-bottom: 40rpx;
}

.section {
  position: relative;
  border-radius: 20rpx;
  padding: 64rpx 16rpx 16rpx 16rpx;
  width: 96%;
  border: 2px solid white;
  background: #ededed;
  margin: 50rpx 0;
}

.section-title-hex {
  position: absolute;
  left: 50%;
  top: -28rpx;
  transform: translateX(-50%);
  width: 260rpx;
  height: 56rpx;
  background: #fff;
  color: #333;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  clip-path: polygon(10% 0, 90% 0, 100% 50%, 90% 100%, 10% 100%, 0 50%);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  z-index: 2;
}

.param-row {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
  flex-wrap: wrap;
}

.param-col {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.param-col2 {
  flex: 1.2;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.param-row text {
  font-size: 26rpx;
  color: #555;
  /* margin-right: 12rpx; */
  /* min-width: 120rpx; */
}

.param-col text ,
.param-col2 text{
  font-size: 24rpx;
  color: #555;
  /* min-width: 120rpx; */
}

.param-input-picker {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 150rpx;
  height: 60rpx;
  border: 2rpx solid #ccc;
  border-radius: 8rpx;
  background: #f7f7f7;
  font-size: 26rpx;
  padding: 0 12rpx;
  margin-right: 18rpx;
}

.param-input-inner {
  width: 0;
  flex: 1;
  height: 60rpx;
  font-size: 26rpx;
  padding: 0 10rpx;

}

.param-input {
  width: 120rpx;
  height: 60rpx;
  border: 2rpx solid #ccc;
  border-radius: 8rpx;
  background: #f7f7f7;
  font-size: 26rpx;
  padding: 0 10rpx;
  margin-right: 10rpx;
}

.param-search-picker,
.param-input,
.param-picker {
  width: 150rpx;
  height: 60rpx;
  border: 2rpx solid #ccc;
  border-radius: 8rpx;
  background: #f7f7f7;
  font-size: 26rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
  color: #666;
  display: flex;
  justify-content: space-between;
}

.param-btn-group {
  display: flex;
  margin-top: 20rpx;
  justify-content: space-around;
}


.param-search-row {
  display: flex;
  align-items: center;
  margin: 30rpx 0;
  width: 96%;
}

.param-search-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 10rpx;
  min-width: 120rpx;
}

.dailog-btcode-container {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  background-color: rgba(83, 83, 83, 0.664);
  position: fixed;
  z-index: 999;
  top: 0;
  left: 0;
  padding-bottom: env(safe-area-inset-bottom);
}

/* BT码弹窗样式 */
.btcode-dialog {
  width: 100%;
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 30rpx;
  box-shadow: 0 -10rpx 30rpx rgba(0, 0, 0, 0.2);
  transform: translateY(0);
  transition: transform 0.3s ease;
  box-sizing: border-box;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #eee;
}

.dialog-header text:first-child {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.icon-guanbi {
  font-size: 36rpx;
  color: #999;
}

.btcode-form {
  /* max-height: 60vh; */
  overflow-y: auto;
  padding-bottom: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  /* padding: 10rpx 0; */
}

.form-item .label {
  width: 140rpx;
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
}

.form-item .value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.picker-value {
  width: 200rpx;
  height: 60rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  background: #f8f8f8;
}

.manufacturer-input,
.year-input,
.month-input,
.day-input,
.serial-input {
  width: 200rpx;
  height: 60rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  background: #f8f8f8;
}

.btcode-preview {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  border-left: 4rpx solid #1abc9c;
  display: flex;
  /* flex-direction: column; */

}

.preview-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 16rpx;
}

.preview-value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  word-break: break-all;
}


/* 滚动条样式 */
.btcode-form::-webkit-scrollbar {
  width: 6rpx;
}

.btcode-form::-webkit-scrollbar-track {
  background: #f1f1f1;
}

.btcode-form::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 3rpx;
}

.btcode-form::-webkit-scrollbar-thumb:hover {
  background: #a1a1a1;
}

/* BT码输入框样式 */
.btcode-input {
  background: #f8f8f8;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  /* padding: 16rpx 20rpx; */
  color: #333;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60rpx;
}

.btcode-input:active {
  background: #e8e8e8;
  border-color: #1abc9c;
}

.param-input.btcode-input {
  cursor: pointer;
}