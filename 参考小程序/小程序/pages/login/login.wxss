.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
}
.title {
  color: #1abc1a;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 60rpx;
}
.input-group {
  width: 80%;
  margin-bottom: 40rpx;
  margin-top: 50rpx;
}
.input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  margin-bottom: 0;
  background: none;
  border: none;
  outline: none;
}
.line {
  width: 100%;
  height: 2rpx;
  background: #e0e0e0;
  margin-bottom: 50rpx;
}
.btn-group {
  width: 80%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

