.dialog-buttons {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
  gap: 30rpx;
}

.dialog-btn {
  padding: 20rpx 30rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
  position: relative;
  top: 0;
  transition: all 0.1s ease;
  border: none;
}

.dialog-btn.small{
  padding: 10rpx 20rpx;
  font-size: 24rpx;
}

.dialog-btn.default{
