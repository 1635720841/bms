  color: white;
  text-shadow: 0 1rpx 1rpx rgba(0, 0, 0, 0.2);
}

.dialog-btn.confirm {
  background: linear-gradient(to bottom, #1abc9c, #18a88c);
  color: white;
  text-shadow: 0 1rpx 1rpx rgba(0, 0, 0, 0.2);
}

.dialog-btn:active {
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  top: 2rpx;
  opacity: 0.9;
}