<!--pages/userManager/editUser/editUser.wxml-->
<view class="container">
  <view class="box_sjfk">
    <text class="text-plza"> <text class="text-red">*</text> 所属组织</text>
    <text class="input-pqqq" >{{org_name}}</text>
  </view>
  <view class="box_sjfk">
    <text class="text-plza"><text class="text-red">*</text> 登录账号</text>
    <text class="input-pqqq"  >{{name}}</text>
   </view>
  <view class="box_sjfk">
    <text class="text-plza">电子邮箱</text>
    <input class="input-pqqq" type="text" maxlength="36" bindinput="onInput" data-index="21" value="{{email}}"></input>
  </view>
  <view class="box_sjfk">
    <text class="text-plza">手机号码</text>
    <input class="input-pqqq" type="number" maxlength="11" bindinput="onInput" data-index="22" value="{{mobile}}"></input>
  </view>
  <view class="box_sjfk">
    <text class="text-plza">备注信息</text>
    <input class="input-pqqq" type="text" maxlength="100" bindinput="onInput" data-index="23" value="{{comment}}"></input>
  </view>


  <view class="dialog-buttons" style="margin:100rpx 0 50rpx 0; width: 96%;">
    <view style="width: 5%;"></view>
    <button class="dialog-btn cancel" catch:tap="onCancel">取消</button>
    <button class="dialog-btn confirm" catch:tap="onSubmit">确定</button>
    <view style="width: 5%;"></view>
  </view>
</view>