<!--pages/groupManager/editOrg/editOrg.wxml-->
<view class="container">

  <view class="box_sjfk">
    <text class="text-plza"><text class="text-red">*</text> 所属组织</text>
    <input class="input-pqqq" type="text" maxlength="30" bindinput="onInput" data-index="1" value="{{org_name}}" disabled="true"  ></input>
  </view>
  <view class="box_sjfk">
    <text class="text-plza">地址</text>
    <input class="input-pqqq" type="text" maxlength="30" bindinput="onInput" data-index="2" value="{{org_addr}}"></input>
  </view>
  <view class="box_sjfk">
    <text class="text-plza">税号</text>
    <input class="input-pqqq" type="text" maxlength="30" bindinput="onInput" data-index="3" value="{{org_tax_id}}"></input>
  </view>
  <view class="box_sjfk">
    <text class="text-plza"><text class="text-red">*</text> 联系人</text>
    <input class="input-pqqq" type="text" maxlength="30" bindinput="onInput" data-index="4" value="{{contact_person1}}"></input>
  </view>
  <view class="box_sjfk">
    <text class="text-plza"><text class="text-red">*</text> 联系号码</text>
    <input class="input-pqqq" type="number" maxlength="11" bindinput="onInput" data-index="5" value="{{contact_number1}}"></input>
  </view>

  <view wx:if="{{item.parent_org_id != -1}}" class="box_sjfk">
    <text class="text-plza">上级组织</text>
    <text class="input-pqqq"  >{{item.parent_org_name}}</text>
  </view>

  <!-- <view wx:if="{{!!usr}}" class="box_sjfk">
    <text class="text-plza"><text class="text-red">*</text> 登录账号</text>
    <text class="input-pqqq" style="border: none;">{{usr.name}}</text>
    <text style="display: flex;align-items: center;justify-content: center;color:#18a88c;" catch:tap="onUserDetail">详情<text class="cuIcon-right"></text></text>
   </view>
 

  <view wx:elif="{{addUserPerm}}" class="dialog-buttons" style="margin: 50rpx 0 0 0; width: 96%;">
    <view style="width:20%;"></view>
    <button class="dialog-btn cancel" catch:tap="onCreatAccount">创建登录账号</button>
    <view style="width:20%;"></view>
  </view> -->
<!-- 协议 start -->
<view class='cb' style="margin-top: 20rpx;">
            <button class="cb-button" id="agree-btn" open-type="agreePrivacyAuthorization" bindagreeprivacyauthorization="handleAgree">
              <image style="width: 42rpx;height: 42rpx;"   src="{{read_protocol?'/images/icon_rb_checkbox_2.png':'/images/icon_rb_checkbox_1.png'}}"></image>
            </button>
             <view   class="txt_wwer">已阅读并同意
              <text class="txt_affd" bindtap="openPrivacyContract">《用户隐私保护协议》</text>
            </view>
          </view>
          <!-- 协议 end -->
  <view class="dialog-buttons" style="margin:100rpx 0 50rpx ; width: 96%;">
    <view style="width: 5%;"></view>
    <button class="dialog-btn cancel" catch:tap="onCancel">取消</button>
    <button class="dialog-btn confirm" catch:tap="onSubmit">确定</button>
    <view style="width: 5%;"></view>
  </view>


</view>

 