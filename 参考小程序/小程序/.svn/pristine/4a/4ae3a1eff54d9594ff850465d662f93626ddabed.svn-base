<!--pages/userManager/userList/userList.wxml-->
<view class="container">
  <!-- 搜索框 -->
  <!-- 顶部输入 -->
  <view class="top-bar">
    <view class="input-bg">
      <input class="device-input" placeholder="请输入组织名/账号名" value="{{searchKey}}" bindinput="onSearchKeyInput" bindconfirm="onSearchKeyConfirm" />
      <text wx:if="{{!!searchKey}}" class="iconfont icon-guanbi" style="font-size: 48rpx;color: gray;padding: 10rpx ;" catch:tap="clearCode"></text>

    </view>
  </view>

  <scroll-view wx:if="{{usr_list && usr_list.length > 0}}" scroll-y="true" style="width: 100%;height:{{winHeight - 50}}px ;margin-top: 10rpx;" bindscrolltolower="loadMore" bindrefresherrefresh="onPullRefresh" refresher-enabled="{{true}}" refresher-triggered="{{refresherTriggered}}" refresher-threshold="10" refresher-background="#f5f5f5">
    <block wx:for="{{usr_list}}" wx:key="usr_id">
      <view class="box_sdaf" catch:tap="onUserDetail" data-item="{{item}}">
        <view class="box_sjfk">
          <text class="text-plza"> 所属组织</text>
          <text>{{item.org_name}}</text>
        </view>
        <view class="box_sjfk">
          <text class="text-plza"> 登录账号</text>
          <text>{{item.usr_name}}</text>
        </view>
        <view class="box_sjfk">
          <text class="text-plza"> 电子邮箱</text>
          <text>{{item.email?item.email:''}}</text>
        </view>
        <view class="box_sjfk">
          <text class="text-plza"> 手机号码</text>
          <text>{{item.mobile?item.mobile:''}}</text>
        </view>
        <view class="box_sjfk">
          <text class="text-plza"> 备注信息</text>
          <text>{{item.comment?item.comment:''}}</text>
        </view>

        <view wx:if="{{updateUserPerm || pwdchgPerm}}" class="dialog-buttons" style="margin:20rpx 0; width: 100%;">
        <button wx:if="{{updateUserPerm}}" class="dialog-btn cancel default" catch:tap="onEditAccount" data-item="{{item}}" data-index="{{index}}">修改信息</button>
        <button wx:if="{{pwdchgPerm}}" class="dialog-btn confirm default" catch:tap="onResetPwd" data-item="{{item}}">重置密码</button>
        <!-- <button  wx:if="{{pwdchgPerm}}"  class="dialog-btn confirm default" catch:tap="onModifyPwd" data-item="{{item}}">修改密码</button> -->
      </view>
      </view>

      

    </block>

  </scroll-view>


</view>