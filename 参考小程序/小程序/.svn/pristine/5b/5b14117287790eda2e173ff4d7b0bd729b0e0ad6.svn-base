/* pages/deviceManager/servicePricing/servicePricing.wxss */

@import "../deviceEntry/deviceEntry.wxss";

.param-search-picker {
  width: 100%;
  height: 80rpx;
  padding: 0 30rpx;
  border: 2rpx solid #e6e4e4;
  border-radius: 8rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  color: #666;
  display: flex;
  justify-content: space-between;
}
