/* 我的页面样式 */

.mine-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: #f7f7f7;
}
.mine-top {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.input-group {
  width: 80%;
  margin-bottom: 40rpx;
  margin-top: 50rpx;
}
.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  color: #eee;
  margin-bottom: 10rpx;
}
.user-info {
  text-align: center;
  display: flex;
  flex-direction: column;
}
.username {
  font-size: 32rpx;
   color: #333;
}
.company {
  font-size: 26rpx;
  color: #888;
  margin-top: 8rpx;
}
.mine-bottom {
  position: absolute;
  bottom: 60rpx;
  left: 0;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.version {
  font-size: 24rpx;
  color: #aaa;
  margin-bottom: 32rpx;
}
.logout-btn, .login-btn {
  width: 60%;
  height: 80rpx;
  font-size: 30rpx;
  border-radius: 40rpx;
  background: #4caf50;
  color: #fff;
  margin-bottom: 16rpx;
  margin-top: 50rpx;
}

.logout-btn {
  background: #f44336;
}

.logout-btn:active, .login-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 菜单列表样式 */
.menu-list {
  width: 100%;
  margin-top: 60rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.menu-arrow {
  width: 24rpx;
  height: 24rpx;
}

.menu-version {
  font-size: 26rpx;
  color: #999;
  margin-right: 10rpx;
}

.menu-item:active {
  background-color: #f9f9f9;
}

/* 禁用版本号行的点击效果 */
.menu-item:not([catchtap]):active {
  background-color: transparent;
}