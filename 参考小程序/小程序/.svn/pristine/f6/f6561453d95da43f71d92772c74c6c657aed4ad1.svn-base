/* pages/deviceManager/deviceEntry/deviceEntry.wxss */

.box_ksaq {
  display: flex;
  height: 80rpx;
  border: 2rpx solid #e6e4e4;
  align-items: center;
  justify-content: space-between;
  border-radius: 10rpx;
  padding: 0 30rpx;
  color: gray;
}

.box_kddf {
  border-radius: 20rpx;
  border: 2rpx solid #e6e4e4;
  height: 300rpx;
   display: flex;
   justify-content: space-between;
   position: relative;
}

.text-jfaf {
  width: 90%;
  height: 100%;
  padding: 10rpx 30rpx;
}

.box_kska {
  width: 100%;
  height: 50rpx;
  font-size: 28rpx;
  color: gray;
  border-bottom: 1rpx solid #f1f1f1;
  display: flex;
  align-items: center;
  padding:  0 30rpx;
}

.text-ad32{
  padding: 4rpx 20rpx;
  border-radius: 90rpx;
  font-size: 24rpx;
  background: linear-gradient(to bottom, #1abc9c, #18a88c);
  color: white;
  text-shadow: 0 1rpx 1rpx rgba(0, 0, 0, 0.2);
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
}